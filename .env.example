RUST_LOG=info
POSTGRES_DB=grid_binance
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgres://postgres:postgres@postgres:5432/grid_binance
REDIS_URL=redis://redis:6379/0
SESSION_TOKEN_SECRET=replace-with-a-long-random-secret
AUTH_EMAIL_DELIVERY=smtp
AUTH_EMAIL_FROM=noreply@example.com
AUTH_EMAIL_SMTP_HOST=mail-relay
AUTH_EMAIL_SMTP_PORT=25
AUTH_EMAIL_SMTP_HELO_NAME=grid-binance.local
AUTH_EMAIL_HTTP_URL=
AUTH_EMAIL_HTTP_BEARER_TOKEN=
EXCHANGE_CREDENTIALS_MASTER_KEY=replace-with-a-dedicated-long-random-secret
BINANCE_LIVE_MODE=0
BINANCE_SPOT_REST_BASE_URL=https://api.binance.com
BINANCE_USDM_REST_BASE_URL=https://fapi.binance.com
BINANCE_COINM_REST_BASE_URL=https://dapi.binance.com
BINANCE_SPOT_WS_BASE_URL=wss://stream.binance.com:9443/ws
BINANCE_USDM_WS_BASE_URL=wss://fstream.binance.com/ws
BINANCE_COINM_WS_BASE_URL=wss://dstream.binance.com/ws
SNAPSHOT_SYNC_INTERVAL_SECS=300
REMINDER_INTERVAL_SECS=300
REMINDER_LOOKAHEAD_HOURS=24
ADMIN_EMAILS=admin@example.com

TELEGRAM_BOT_BIND_SECRET=replace-with-a-dedicated-telegram-bot-secret
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_BASE_URL=https://api.telegram.org
INTERNAL_SHARED_SECRET=replace-with-a-dedicated-internal-service-secret
CHAIN_RPC_URL_ETH=https://ethereum-rpc.example.com
CHAIN_RPC_URL_BSC=https://bsc-rpc.example.com
CHAIN_RPC_URL_SOL=https://solana-rpc.example.com
SWEEP_EXECUTOR_URL=https://sweep-executor.example.com/submit
SWEEP_EXECUTOR_AUTH_TOKEN=
CHAIN_TOKEN_CONTRACT_ETH_USDT=
CHAIN_TOKEN_CONTRACT_ETH_USDC=
CHAIN_TOKEN_CONTRACT_BSC_USDT=
CHAIN_TOKEN_CONTRACT_BSC_USDC=
CHAIN_TOKEN_MINT_SOL_USDT=
CHAIN_TOKEN_MINT_SOL_USDC=
CHAIN_LISTENER_RPC_POLL_INTERVAL_SECS=30
CHAIN_LISTENER_EVM_INITIAL_LOOKBACK_BLOCKS=128
CHAIN_LISTENER_SOL_SIGNATURE_LIMIT=100
